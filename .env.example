# Runtime
NODE_ENV=production
PORT=3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=sha256:replace_with_sha256_hex_of_admin_password
ADMIN_TOKEN=change_me_admin_token_before_deploy
ADMIN_JWT_SECRET=change_me_admin_jwt_secret_before_deploy_minimum_32_chars
CREDENTIAL_ENCRYPTION_KEY=change_me_credential_encryption_key_before_deploy_minimum_32_chars
PRICE_SYNC_CRON=0 0 * * *

# Graceful shutdown
SHUTDOWN_TIMEOUT_MS=10000
